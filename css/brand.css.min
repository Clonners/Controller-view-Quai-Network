:root{color-scheme:dark;--bg:#050307;--bg-alt:#0a0509;--panel:#12070b;--panel-2:#1a0a10;--border:#301219;--border-strong:rgba(255,37,58,0.34);--accent:#ff253a;--accent-soft:rgba(255,37,58,0.18);--text:#e5e7eb;--text-dim:#c0c6d2;--muted:#9ca3af;--dim:#8b92a0;--danger:#ff4b4b;--success:#4ade80;--green:#4ade80;--card-radius:16px;--radius-lg:28px;--radius-md:18px;--max:1180px;--shadow-soft:0 18px 45px rgba(0,0,0,0.7);--shadow:0 28px 80px rgba(0,0,0,0.72);--font:system-ui,-apple-system,BlinkMacSystemFont,"SF Pro Text","Segoe UI",sans-serif;--mono:'JetBrains Mono','Fira Code','Cascadia Code','SF Mono',ui-monospace,Consolas,monospace;}*{margin:0;padding:0;box-sizing:border-box;}body{margin:0;font-family:var(--font);background:radial-gradient(circle at top,#2b0005 0,var(--bg) 40%,#020005 80%);color:var(--text);min-height:100vh;overflow-x:hidden;}@keyframes floatIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}@keyframes pulseDot{0%{transform:scale(1);opacity:0.9;}50%{transform:scale(1.4);opacity:0.4;}100%{transform:scale(1);opacity:0.9;}}@keyframes slideIn{from{opacity:0;transform:translateX(-10px);}to{opacity:1;transform:translateX(0);}}@keyframes glowPulse{0%,100%{box-shadow:0 0 20px rgba(255,37,58,0.3);}50%{box-shadow:0 0 40px rgba(255,37,58,0.6);}}@keyframes spin{to{transform:rotate(360deg);}}@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}@keyframes shimmer{0%{background-position:-200% 0;}100%{background-position:200% 0;}}.card{background:radial-gradient(circle at top left,#1a060b 0,#060106 55%);border-radius:var(--card-radius);border:1px solid rgba(56,12,24,0.9);box-shadow:var(--shadow-soft);padding:16px;position:relative;overflow:hidden;transition:border-color 0.15s ease,box-shadow 0.15s ease,transform 0.15s ease;animation:floatIn 0.7s ease-out both;}.card::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at top right,rgba(255,37,58,0.18),transparent 55%);opacity:0.9;pointer-events:none;}.card:hover{border-color:var(--accent);box-shadow:0 22px 54px rgba(255,37,58,0.35);transform:translateY(-2px);}.card-header{position:relative;z-index:1;display:flex;justify-content:space-between;align-items:baseline;gap:8px;margin-bottom:10px;}.card-title{font-size:0.9rem;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;color:var(--text);}.card-subtitle{font-size:0.75rem;color:var(--muted);}.btn,button.primary{border-radius:999px;border:none;padding:7px 16px;font-size:0.85rem;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,var(--accent),#ff7a3c);color:#050308;box-shadow:0 10px 24px rgba(255,37,58,0.6);white-space:nowrap;transition:transform 0.12s ease,box-shadow 0.12s ease,filter 0.12s ease;letter-spacing:0.03em;text-transform:uppercase;}.btn:hover:not(:disabled),button.primary:hover:not(:disabled){transform:translateY(-1px) scale(1.02);box-shadow:0 16px 32px rgba(255,37,58,0.7);filter:brightness(1.05);}.btn:disabled{opacity:0.6;cursor:not-allowed;}.btn-secondary,button.secondary{background:transparent;color:var(--muted);border:1px solid rgba(148,163,184,0.3);box-shadow:none;}.btn-secondary:hover:not(:disabled),button.secondary:hover:not(:disabled){background:rgba(248,250,252,0.12);border-color:rgba(255,255,255,0.6);color:#e5e7eb;}input[type="text"],input[type="number"],input[type="email"],input[type="password"],select,textarea{background:rgba(10,2,9,0.95);border-radius:999px;border:1px solid rgba(148,27,49,0.8);padding:8px 14px;color:var(--text);font-size:0.85rem;outline:none;min-width:0;transition:border-color 0.15s ease,box-shadow 0.15s ease,background 0.15s ease;font-family:var(--font);}input:focus,select:focus,textarea:focus{border-color:var(--accent);box-shadow:0 0 0 1px rgba(255,37,58,0.32);background:rgba(10,2,10,1);}.pill{border-radius:999px;padding:4px 10px;font-size:0.7rem;border:1px solid rgba(75,85,99,0.7);color:var(--muted);display:inline-flex;align-items:center;gap:6px;background:rgba(7,3,7,0.95);}.pill-dot{width:6px;height:6px;border-radius:50%;background:var(--success);animation:pulseDot 1.8s ease-out infinite;}.pill-dot.red{background:var(--danger);animation:none;}.pill-dot.fetching{width:14px;height:14px;background:transparent !important;border:2px solid rgba(255,255,255,0.08);border-top-color:var(--success);animation:spin 0.9s linear infinite;}.nav-pill{padding:8px 14px;border-radius:999px;background:rgba(255,37,58,0.08);color:var(--text);text-decoration:none;border:1px solid rgba(255,37,58,0.08);font-weight:600;display:inline-flex;align-items:center;gap:6px;font-size:0.78rem;transition:background 0.15s ease;}.nav-pill:hover{background:rgba(255,37,58,0.14);}.mono{font-family:var(--mono);font-size:0.82em;}.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;}::-webkit-scrollbar{width:6px;height:6px;}::-webkit-scrollbar-track{background:var(--bg);}::-webkit-scrollbar-thumb{background:rgba(255,37,58,0.25);border-radius:999px;}::-webkit-scrollbar-thumb:hover{background:rgba(255,37,58,0.45);}